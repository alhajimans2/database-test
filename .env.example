# Core
SECRET_KEY=replace-with-strong-secret
APP_ENV=production
FLASK_DEBUG=false
PORT=5000

# Database (Render/Railway PostgreSQL)
DATABASE_URL=postgresql+psycopg://user:password@host:5432/database
DB_SSLMODE=require

# Security / proxy
COOKIE_SECURE=true
TRUST_PROXY=true

# CORS (comma-separated frontend origins)
CORS_ORIGINS=https://your-frontend-domain.netlify.app

# Optional admin bootstrap (run once, then set false)
CREATE_DEFAULT_ADMIN=false
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me-now

# Gunicorn tuning
WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info

# Optional mail / OTP
MAIL_ENABLED=false
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_USE_SSL=false
MAIL_FROM=
ADMIN_OTP_ENABLED=false

# Optional observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.2

# Netlify frontend function (set in Netlify env when using proxy.js)
BACKEND_URL=https://your-backend-domain.onrender.com
